# ==========================================================================
# JP Corporate - Environment Variables
# Copy this file to .env (and into backend/.env and rag-service/.env) and fill in.
# ==========================================================================

# --- Neon PostgreSQL (with pgvector) ---
# Get this from https://console.neon.tech (use the pooled or direct connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# --- Groq (free chatbot API) ---
# Get a free key (no credit card) from https://console.groq.com
GROQ_API_KEY="gsk_your_groq_api_key_here"
GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_BASE_URL="https://api.groq.com/openai/v1"

# --- Auth ---
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Seeded admin account (created by `npm run db:seed`)
ADMIN_EMAIL="admin@jp-corporate.local"
ADMIN_PASSWORD="admin1234"

# --- Service URLs / ports ---
BACKEND_PORT="4000"
BACKEND_HOST="0.0.0.0"
RAG_SERVICE_URL="http://localhost:8000"
FRONTEND_ORIGIN="http://localhost:3000,http://YOUR_IP:3000"
# Allow any host on port 3000 (e.g. http://192.168.1.10:3000) for LAN access
CORS_ALLOW_LAN="true"
ALLOWED_DEV_ORIGINS="103.179.45.76,localhost"

# --- Frontend (Next.js public env) ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"

# --- RAG embedding model (sentence-transformers, runs locally / free) ---
EMBEDDING_MODEL="all-MiniLM-L6-v2"
EMBEDDING_DIM="384"
