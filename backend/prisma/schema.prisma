generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String   @default("Administrator")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Singleton-ish global site configuration (hero, contact, theme, branding).
model SiteSetting {
  id            String   @id @default(cuid())
  companyName   String   @default("JP Corporate")
  tagline       String   @default("")
  heroTitle     String   @default("")
  heroSubtitle  String   @default("")
  heroImageUrl  String   @default("")
  aboutTitle    String   @default("About Us")
  aboutBody     String   @default("")
  email         String   @default("")
  phone         String   @default("")
  address       String   @default("")
  accentColor   String   @default("#2563eb")
  socialLinks   Json     @default("{}")
  stats         Json     @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String   @default("sparkles")
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PortfolioItem {
  id          String   @id @default(cuid())
  title       String
  client      String   @default("")
  category    String   @default("")
  description String
  imageUrl    String   @default("")
  link        String   @default("")
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id          String   @id @default(cuid())
  authorName  String
  authorRole  String   @default("")
  company     String   @default("")
  avatarUrl   String   @default("")
  quote       String
  rating      Int      @default(5)
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NewsPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String   @default("")
  body        String
  coverUrl    String   @default("")
  category    String   @default("News")
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  bio       String   @default("")
  photoUrl  String   @default("")
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VisitorSession {
  id        String         @id @default(cuid())
  ip        String         @default("")
  city      String         @default("Unknown")
  region    String         @default("")
  country   String         @default("")
  email     String         @default("N/A")
  userAgent String         @default("")
  referrer  String         @default("")
  createdAt DateTime       @default(now())
  lastSeen  DateTime       @default(now())
  events    VisitorEvent[]

  @@index([createdAt])
}

enum VisitorEventType {
  pageview
  click
}

model VisitorEvent {
  id        String           @id @default(cuid())
  sessionId String
  session   VisitorSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      VisitorEventType
  label     String           @default("")
  path      String           @default("")
  createdAt DateTime         @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

model ChatConversation {
  id        String        @id @default(cuid())
  sessionId String?
  visitorIp String        @default("")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([createdAt])
}

enum ChatRole {
  user
  assistant
  system
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           ChatRole
  content        String
  createdAt      DateTime         @default(now())

  @@index([conversationId])
}

/// Source documents for RAG. Embeddings live in the `rag_embeddings` table
/// (managed via raw SQL because Prisma has no native vector type).
model RagDocument {
  id        String   @id @default(cuid())
  title     String   @default("Untitled")
  content   String
  source    String   @default("manual")
  chunks    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
